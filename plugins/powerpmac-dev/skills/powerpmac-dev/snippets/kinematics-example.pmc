// Power PMAC 키네마틱 서브루틴 예제 모음
// Power PMAC User's Manual(UM)에서 그대로 수집한 코드.
// 2축 "어깨-팔꿈치" 로봇: 상완 L1=400mm, 전완 L2=300mm,
// 각 관절 1000 counts/degree. IDE가 Kin* 이름을 자동 치환:
//   KinPosMotor1 = L1, KinPosMotor2 = L2,
//   KinPosAxisX = C6, KinPosAxisY = C7, KinAxisUsed = D0, KinVelEna = D0.

// === 순기구학(forward kinematics) 프로그램 권장 구조 (source: UM p514) ===
// 이중 패스 옵션: &xv / &xf 속도 조회를 위해 callsub로 두 번째 패스를 수행.
open forward
if (KinVelEna > 0) callsub 100;
KinAxisUsed = {axis mask}
n100:
{kinematic calculations}
return;
close


// === 어깨-팔꿈치 순기구학, CS 1 (source: UM p515-516) ===
// 순기구학: 관절 각도(모터 counts) -> X,Y 끝점 좌표(mm) 변환.
//   X = L1*cos(A) + L2*cos(A+B)
//   Y = L1*sin(A) + L2*sin(A+B)

// 프로그램 초기 설정
// 자동 할당 변수 선언
csglobal Len1, Len2;  // 링크 길이 변수
csglobal CtsPerDeg;  // 각 관절의 분해능
csglobal FwdKinErr;  // 루틴 오류 플래그

&1
Len1 = 400    // 상완 링크 400mm
Len2 = 300    // 전완 링크 300mm
CtsPerDeg = 1000   // A 및 B 관절의 counts/degree

// 변수 이름 치환 (IDE가 자동으로 수행)
//#define KinPosMotor1 L1
//#define KinPosMotor2 L2
//#define KinPosAxisX C6
//#define KinPosAxisY C7
//#define KinAxisUsed D0

// 반복 실행을 위한 순기구학 프로그램 버퍼
&1
open forward
if (KinVelEna) callsub 100;
KinAxisUsed = $C0   // X축 및 Y축 결과
N100: if (Coord[1].HomeComplete) {  // 유효한가?
  KinPosAxisX = Len1 * cosd(KinPosMotor1 / CtsPerDeg) +
      Len2 * cosd((KinPosMotor1 + KinPosMotor2) / CtsPerDeg - 90);
  KinPosAxisY = Len1 * sind(KinPosMotor1 / CtsPerDeg)+
      Len2 * sind((KinPosMotor1 + KinPosMotor2) / CtsPerDeg - 90);
}
else {    // 유효하지 않음; 동작 정지
  if (Ldata.Status & 40) { // 모션 프로그램에서 호출된 경우?
    Coord[1].ErrorStatus = 255; // 사용자 정의 중단 오류
  }
  else {    // 축 조회에서 호출된 경우
    KinPosAxisX = sqrt(-1); // "not-a-number" 반환
    KinPosAxisY = sqrt(-1); // "not-a-number" 반환
  }
}
return;
close


// === 어깨-팔꿈치 역기구학, CS 1 (source: UM p518-519) ===
// 역기구학: X,Y 끝점 좌표(mm) -> 관절 각도(모터 counts) 변환.
// "오른팔(right-armed)" 경우(팔꿈치 각도 B가 양수)만 처리.

// 프로그램 초기 설정
&1  // 축 정의를 위해 CS1 지정
#1->I  // 모터 1을 CS 1의 역기구학 축에 할당
#2->I  // 모터 2를 CS 1의 역기구학 축에 할당

// 자동 할당 변수 선언
// (순기구학 예제에서 선언된 변수도 함께 사용)
csglobal SumLenSqrd   // Len1^2 + Len2^2
csglobal ProdOfLens   // 2*Len1*Len2
csglobal DifLenSqrd   // Len1^2 - Len2^2
csglobal InvKinErr    // 루틴 오류 플래그

// 추가 시스템 상수 사전 계산
&1
SumLenSqrd = Len1 * Len1 + Len2 * Len2
ProdOfLens = 2 * Len1 * Len2
DifLenSqrd = Len1 * Len1 - Len2 * Len2

// 반복 실행될 역기구학 알고리즘
&1
open inverse    // 버퍼 열기 및 내용 초기화

// 루틴용 로컬 변수 선언
local X2Y2     // X^2 + Y^2
local Bcos     // cos(팔꿈치 각)
local Bangle    // 팔꿈치 각도 (deg)
local AplusC    // A와 C 각도의 합 (deg)
local Cangle    // 삼각형의 C 각도 (deg)
local Aangle    // 어깨 각도 (deg)

X2Y2 = KinPosAxisX * KinPosAxisX + KinPosAxisY * KinPosAxisY;
Bcos = (X2Y2 - SumLenSqrd) / ProdOfLens;
If (abs(Bcos) < 0.9998) {  // 1도 여유를 포함한 유효한 해인가?
    Bangle = acosd(Bcos);
    AplusC = atan2d(KinPosAxisY, KinPosAxisX);
    Cangle = acosd((X2Y2 + DifLenSqrd) / (2 * Len1 * sqrt(X2Y2)));
    Aangle = AplusC - Cangle;
    KinPosMotor1 = Aangle * CtsPerDeg;
    KinPosMotor2 = (Bangle + 90) * CtsPerDeg;
    InvKinErr = 0;
}
else {     // 유효하지 않음, 동작 정지
    InvKinErr = 1;   // 외부 참조용 플래그 설정
    Coord[1].ErrorStatus = 255; // 실행 중지
}
close
